:root {
  --home-v2-bg: #07101f;
  --home-v2-panel: rgba(10, 23, 43, 0.96);
  --home-v2-card: rgba(13, 31, 56, 0.88);
  --home-v2-card-soft: rgba(16, 39, 70, 0.7);
  --home-v2-border: rgba(96, 165, 250, 0.22);
  --home-v2-border-bright: rgba(96, 165, 250, 0.5);
  --home-v2-text: #e5f3ff;
  --home-v2-muted: #8faac6;
  --home-v2-blue: #60a5fa;
  --home-v2-green: #39ff88;
  --home-v2-gold: #facc15;
  --home-v2-red: #fb7185;
  --home-v2-orange: #fb923c;
  --home-v2-shadow: 0 18px 55px rgba(0, 0, 0, 0.32);
}

.home-v2-body {
  min-height: 100vh;
  background:
    radial-gradient(
      circle at 15% 10%,
      rgba(37, 99, 235, 0.13),
      transparent 35%
    ),
    radial-gradient(
      circle at 85% 20%,
      rgba(34, 197, 94, 0.08),
      transparent 28%
    ),
    var(--home-v2-bg);
}

.home-v2-wrap {
  max-width: 1540px;
}

.home-v2-panel {
  background:
    linear-gradient(
      180deg,
      rgba(12, 27, 50, 0.98),
      rgba(6, 17, 33, 0.98)
    );
  box-shadow: var(--home-v2-shadow);
}

.home-v2-header {
  align-items: flex-start;
}

.home-v2-title-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.home-v2-title-row h1 {
  margin: 0;
}

.version-pill {
  display: inline-flex;
  align-items: center;
  min-height: 26px;
  padding: 3px 10px;
  border: 1px solid rgba(96, 165, 250, 0.42);
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
  color: #93c5fd;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.12em;
}

.home-v2-header-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.home-v2-updated {
  color: var(--home-v2-muted);
  font-size: 0.78rem;
}

.home-v2-status-strip {
  overflow-x: auto;
}

.home-v2-status-strip .status-chip.pending span {
  background: #64748b;
  box-shadow: none;
}

.home-v2-status-strip .status-chip.warning span {
  background: var(--home-v2-gold);
  box-shadow: 0 0 12px rgba(250, 204, 21, 0.7);
}

.home-v2-status-strip .status-chip.critical span {
  background: var(--home-v2-red);
  box-shadow: 0 0 12px rgba(251, 113, 133, 0.7);
}

.home-v2-hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 2fr) minmax(320px, 0.8fr);
  gap: 18px;
  margin-top: 18px;
}

.home-v2-hero-card,
.home-v2-health-card {
  min-height: 220px;
}

.home-v2-hero-card {
  position: relative;
  overflow: hidden;
  padding: 28px;
  background:
    radial-gradient(
      circle at 85% 20%,
      rgba(96, 165, 250, 0.18),
      transparent 40%
    ),
    linear-gradient(
      135deg,
      rgba(15, 41, 75, 0.96),
      rgba(8, 26, 51, 0.95)
    );
}

.home-v2-hero-card::after {
  content: "";
  position: absolute;
  right: -70px;
  bottom: -110px;
  width: 320px;
  height: 320px;
  border: 1px solid rgba(96, 165, 250, 0.12);
  border-radius: 50%;
  box-shadow:
    0 0 0 38px rgba(96, 165, 250, 0.035),
    0 0 0 76px rgba(96, 165, 250, 0.025);
}

.home-v2-eyebrow {
  color: #93c5fd;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

.home-v2-hero-number {
  position: relative;
  z-index: 1;
  margin-top: 18px;
  color: var(--home-v2-text);
  font-size: clamp(2.8rem, 6vw, 5.4rem);
  font-weight: 900;
  letter-spacing: -0.055em;
  line-height: 0.95;
  text-shadow: 0 0 28px rgba(96, 165, 250, 0.26);
}

.home-v2-hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18px;
  color: var(--home-v2-muted);
  font-size: 0.95rem;
}

.home-v2-hero-bar {
  position: relative;
  z-index: 1;
  height: 8px;
  margin-top: 30px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.1);
}

.home-v2-hero-bar div {
  width: 0;
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(
      90deg,
      #2563eb,
      #60a5fa,
      #39ff88
    );
  box-shadow: 0 0 18px rgba(96, 165, 250, 0.6);
  transition: width 700ms ease;
}

.home-v2-health-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 28px;
}

.home-v2-health-copy {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.home-v2-health-copy strong {
  color: var(--home-v2-green);
  font-size: 3.5rem;
  line-height: 1;
}

.home-v2-health-copy span {
  color: var(--home-v2-muted);
}

.home-v2-health-ring-wrap {
  position: relative;
  width: 138px;
  min-width: 138px;
  height: 138px;
}

.home-v2-health-ring {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.home-v2-health-ring-track,
.home-v2-health-ring-value {
  fill: none;
  stroke-width: 10;
}

.home-v2-health-ring-track {
  stroke: rgba(96, 165, 250, 0.11);
}

.home-v2-health-ring-value {
  stroke: var(--home-v2-green);
  stroke-linecap: round;
  stroke-dasharray: 314.159;
  stroke-dashoffset: 314.159;
  filter: drop-shadow(0 0 8px rgba(57, 255, 136, 0.45));
  transition:
    stroke-dashoffset 700ms ease,
    stroke 300ms ease;
}

.home-v2-health-ring-wrap > span {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: var(--home-v2-text);
  font-size: 1.45rem;
  font-weight: 900;
}

.home-v2-metrics {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 14px;
  margin-top: 18px;
}

.home-v2-metrics .metric-card {
  min-height: 108px;
}

.home-v2-section {
  margin-top: 18px;
}

.home-v2-section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 18px;
}

.home-v2-section-count,
.home-v2-chart-total {
  color: #93c5fd;
  font-size: 0.86rem;
  font-weight: 800;
  white-space: nowrap;
}

.home-v2-coin-grid {
  display: grid;
  grid-template-columns: repeat(
    auto-fit,
    minmax(245px, 1fr)
  );
  gap: 14px;
}

.home-v2-coin-card {
  position: relative;
  min-height: 210px;
  overflow: hidden;
  padding: 20px;
  border: 1px solid var(--home-v2-border);
  border-radius: 14px;
  background:
    linear-gradient(
      150deg,
      rgba(18, 43, 77, 0.9),
      rgba(10, 28, 53, 0.92)
    );
  transition:
    transform 160ms ease,
    border-color 160ms ease,
    box-shadow 160ms ease;
}

.home-v2-coin-card:hover {
  transform: translateY(-2px);
  border-color: var(--home-v2-border-bright);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
}

.home-v2-coin-card::after {
  content: attr(data-symbol);
  position: absolute;
  right: 14px;
  bottom: -18px;
  color: rgba(255, 255, 255, 0.035);
  font-size: 5.5rem;
  font-weight: 950;
  pointer-events: none;
}

.home-v2-coin-card.mining {
  border-color: rgba(57, 255, 136, 0.34);
}

.home-v2-coin-card.node-online {
  border-color: rgba(96, 165, 250, 0.38);
}

.home-v2-coin-card.offline {
  opacity: 0.72;
}

.home-v2-coin-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.home-v2-coin-symbol {
  color: var(--home-v2-text);
  font-size: 1.5rem;
  font-weight: 900;
}

.home-v2-coin-name {
  margin-top: 4px;
  color: var(--home-v2-muted);
  font-size: 0.82rem;
}

.home-v2-state-badge {
  display: inline-flex;
  align-items: center;
  min-height: 25px;
  padding: 3px 9px;
  border: 1px solid rgba(96, 165, 250, 0.3);
  border-radius: 999px;
  color: #93c5fd;
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.home-v2-state-badge.mining,
.home-v2-state-badge.active,
.home-v2-state-badge.online {
  border-color: rgba(57, 255, 136, 0.4);
  background: rgba(57, 255, 136, 0.08);
  color: var(--home-v2-green);
}

.home-v2-state-badge.warning {
  border-color: rgba(250, 204, 21, 0.4);
  color: var(--home-v2-gold);
}

.home-v2-state-badge.critical,
.home-v2-state-badge.offline {
  border-color: rgba(251, 113, 133, 0.4);
  color: var(--home-v2-red);
}

.home-v2-coin-hashrate {
  margin-top: 25px;
  color: var(--home-v2-text);
  font-size: 1.9rem;
  font-weight: 900;
}

.home-v2-coin-hashrate small {
  display: block;
  margin-top: 5px;
  color: var(--home-v2-muted);
  font-size: 0.73rem;
  font-weight: 500;
}

.home-v2-coin-stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 9px;
  margin-top: 22px;
}

.home-v2-mini-stat {
  padding: 10px;
  border: 1px solid rgba(96, 165, 250, 0.12);
  border-radius: 10px;
  background: rgba(5, 17, 33, 0.4);
}

.home-v2-mini-stat strong {
  display: block;
  color: var(--home-v2-text);
  font-size: 1rem;
}

.home-v2-mini-stat span {
  display: block;
  margin-top: 4px;
  color: var(--home-v2-muted);
  font-size: 0.68rem;
}

.home-v2-pool-grid {
  display: grid;
  grid-template-columns: repeat(
    auto-fit,
    minmax(290px, 1fr)
  );
  gap: 14px;
}

.home-v2-pool-card {
  padding: 19px;
  border: 1px solid var(--home-v2-border);
  border-radius: 14px;
  background:
    linear-gradient(
      145deg,
      rgba(14, 37, 68, 0.9),
      rgba(8, 24, 47, 0.9)
    );
}

.home-v2-pool-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.home-v2-pool-card h3 {
  margin: 0;
  color: var(--home-v2-text);
  font-size: 1rem;
}

.home-v2-pool-endpoint {
  margin-top: 5px;
  color: var(--home-v2-muted);
  font-family: monospace;
  font-size: 0.74rem;
}

.home-v2-pool-hashrate {
  margin-top: 21px;
  color: var(--home-v2-blue);
  font-size: 1.75rem;
  font-weight: 900;
}

.home-v2-pool-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 17px;
}

.home-v2-pool-progress {
  height: 7px;
  margin-top: 18px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.09);
}

.home-v2-pool-progress div {
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(
      90deg,
      var(--home-v2-blue),
      var(--home-v2-green)
    );
}

.home-v2-two-column {
  display: grid;
  grid-template-columns: minmax(0, 1.55fr) minmax(380px, 0.9fr);
  gap: 18px;
  margin-top: 18px;
}

.home-v2-chart-card {
  min-width: 0;
}

.home-v2-line-chart {
  width: 100%;
  min-height: 390px;
}

.home-v2-chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
  min-height: 28px;
  margin-bottom: 10px;
}

.home-v2-chart-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  color: var(--home-v2-muted);
  font-size: 0.74rem;
}

.home-v2-chart-legend-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  box-shadow: 0 0 9px currentColor;
}

.home-v2-miner-list,
.home-v2-node-list,
.home-v2-alert-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.home-v2-miner-row {
  display: grid;
  grid-template-columns: 48px minmax(0, 1fr) auto;
  gap: 13px;
  align-items: center;
  padding: 13px;
  border: 1px solid rgba(96, 165, 250, 0.14);
  border-radius: 12px;
  background: rgba(7, 20, 39, 0.48);
}

.home-v2-miner-rank {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border: 1px solid rgba(96, 165, 250, 0.27);
  border-radius: 12px;
  background: rgba(37, 99, 235, 0.12);
  color: #93c5fd;
  font-weight: 900;
}

.home-v2-miner-name {
  color: var(--home-v2-text);
  font-weight: 800;
}

.home-v2-miner-pool {
  margin-top: 4px;
  color: var(--home-v2-muted);
  font-size: 0.75rem;
}

.home-v2-miner-values {
  text-align: right;
}

.home-v2-miner-values strong {
  display: block;
  color: var(--home-v2-green);
}

.home-v2-miner-values span {
  display: block;
  margin-top: 4px;
  color: var(--home-v2-muted);
  font-size: 0.7rem;
}

.home-v2-node-row,
.home-v2-alert-row {
  padding: 15px;
  border: 1px solid rgba(96, 165, 250, 0.14);
  border-radius: 12px;
  background: rgba(7, 20, 39, 0.48);
}

.home-v2-node-row-header,
.home-v2-alert-row-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 13px;
}

.home-v2-node-row h3,
.home-v2-alert-row h3 {
  margin: 0;
  color: var(--home-v2-text);
  font-size: 0.94rem;
}

.home-v2-node-host,
.home-v2-alert-source {
  margin-top: 4px;
  color: var(--home-v2-muted);
  font-family: monospace;
  font-size: 0.72rem;
}

.home-v2-node-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 14px;
}

.home-v2-alert-row.warning {
  border-color: rgba(250, 204, 21, 0.28);
}

.home-v2-alert-row.critical {
  border-color: rgba(251, 113, 133, 0.35);
}

.home-v2-alert-message {
  margin-top: 10px;
  color: var(--home-v2-muted);
  font-size: 0.8rem;
  line-height: 1.45;
}

.home-v2-all-clear {
  padding: 26px;
  border: 1px solid rgba(57, 255, 136, 0.24);
  border-radius: 12px;
  background: rgba(57, 255, 136, 0.05);
  color: var(--home-v2-green);
  text-align: center;
  font-weight: 800;
}

.home-v2-activity-feed {
  display: grid;
  grid-template-columns: repeat(
    auto-fit,
    minmax(300px, 1fr)
  );
  gap: 10px;
}

.home-v2-activity-feed .event {
  min-height: 66px;
}

.home-v2-loading,
.home-v2-empty {
  padding: 28px;
  border: 1px dashed rgba(96, 165, 250, 0.18);
  border-radius: 12px;
  color: var(--home-v2-muted);
  text-align: center;
}

.home-v2-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 20px 4px 4px;
  color: var(--home-v2-muted);
  font-size: 0.76rem;
}

.home-v2-footer a {
  color: #93c5fd;
  text-decoration: none;
}

.home-v2-footer a:hover {
  text-decoration: underline;
}

body.command-tv .home-v2-footer {
  display: none;
}

@media (max-width: 1180px) {
  .home-v2-metrics {
    grid-template-columns: repeat(3, 1fr);
  }

  .home-v2-two-column {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .home-v2-hero-grid {
    grid-template-columns: 1fr;
  }

  .home-v2-health-card {
    min-height: auto;
  }

  .home-v2-metrics {
    grid-template-columns: repeat(2, 1fr);
  }

  .home-v2-header-status {
    align-items: flex-start;
  }

  .home-v2-line-chart {
    min-height: 320px;
  }
}

@media (max-width: 560px) {
  .home-v2-metrics {
    grid-template-columns: 1fr;
  }

  .home-v2-hero-card,
  .home-v2-health-card {
    padding: 20px;
  }

  .home-v2-health-card {
    flex-direction: column;
    align-items: flex-start;
  }

  .home-v2-miner-row {
    grid-template-columns: 42px minmax(0, 1fr);
  }

  .home-v2-miner-values {
    grid-column: 2;
    text-align: left;
  }

  .home-v2-pool-stats,
  .home-v2-node-stats {
    grid-template-columns: 1fr;
  }

  .home-v2-footer {
    flex-direction: column;
    align-items: flex-start;
  }
}
