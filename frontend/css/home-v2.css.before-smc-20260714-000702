:root {
  --nx-bg: #050c18;
  --nx-bg-2: #081325;
  --nx-panel: rgba(8, 20, 39, 0.92);
  --nx-card: rgba(10, 27, 51, 0.88);
  --nx-card-2: rgba(13, 35, 65, 0.9);

  --nx-border: rgba(96, 165, 250, 0.22);
  --nx-border-bright: rgba(96, 165, 250, 0.48);

  --nx-text: #eef7ff;
  --nx-muted: #89a6c3;
  --nx-soft: #5f7d9d;

  --nx-blue: #60a5fa;
  --nx-blue-2: #2563eb;
  --nx-green: #39ff88;
  --nx-gold: #facc15;
  --nx-orange: #fb923c;
  --nx-red: #fb7185;
  --nx-purple: #a78bfa;
  --nx-cyan: #22d3ee;

  --nx-shadow:
    0 24px 80px rgba(0, 0, 0, 0.38);

  --nx-glow-blue:
    0 0 30px rgba(96, 165, 250, 0.16);

  --nx-glow-green:
    0 0 28px rgba(57, 255, 136, 0.16);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--nx-bg);
}

body.home-v2-body {
  min-height: 100vh;
  margin: 0;
  color: var(--nx-text);
  background:
    radial-gradient(
      circle at 15% 5%,
      rgba(37, 99, 235, 0.16),
      transparent 34%
    ),
    radial-gradient(
      circle at 90% 18%,
      rgba(34, 211, 238, 0.08),
      transparent 30%
    ),
    radial-gradient(
      circle at 48% 92%,
      rgba(57, 255, 136, 0.05),
      transparent 34%
    ),
    linear-gradient(
      180deg,
      #07111f,
      #040a14 65%,
      #050c18
    );
}

body.home-v2-body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.18;
  background-image:
    linear-gradient(
      rgba(96, 165, 250, 0.04) 1px,
      transparent 1px
    ),
    linear-gradient(
      90deg,
      rgba(96, 165, 250, 0.04) 1px,
      transparent 1px
    );
  background-size: 48px 48px;
  mask-image:
    linear-gradient(
      to bottom,
      black,
      transparent 88%
    );
}

.home-v2-wrap {
  position: relative;
  z-index: 1;
  width: min(1680px, calc(100% - 38px));
  max-width: none;
  margin: 18px auto 44px;
}

.home-v2-panel {
  position: relative;
  overflow: hidden;
  padding: 22px;
  border: 1px solid rgba(96, 165, 250, 0.34);
  border-radius: 26px;
  background:
    linear-gradient(
      180deg,
      rgba(9, 24, 46, 0.96),
      rgba(5, 15, 30, 0.97)
    );
  box-shadow:
    var(--nx-shadow),
    inset 0 1px 0 rgba(255, 255, 255, 0.025);
}

.home-v2-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(
      circle at 50% -20%,
      rgba(96, 165, 250, 0.11),
      transparent 34%
    );
}

.home-v2-header {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22px;
  padding: 26px 28px;
  border: 1px solid var(--nx-border);
  border-radius: 22px;
  background:
    linear-gradient(
      135deg,
      rgba(11, 31, 59, 0.98),
      rgba(7, 19, 38, 0.96)
    );
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    0 12px 35px rgba(0, 0, 0, 0.22);
}

.home-v2-title-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.home-v2-title-row h1 {
  margin: 0;
  color: var(--nx-text);
  font-size: clamp(2rem, 4vw, 3.4rem);
  letter-spacing: -0.045em;
  line-height: 1;
  text-shadow:
    0 0 30px rgba(96, 165, 250, 0.13);
}

.home-v2-header p {
  margin: 13px 0 0;
  color: #7ec8ff;
  font-size: 0.92rem;
}

.version-pill {
  display: inline-flex;
  align-items: center;
  min-height: 29px;
  padding: 4px 11px;
  border: 1px solid rgba(96, 165, 250, 0.46);
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
  color: #93c5fd;
  font-size: 0.69rem;
  font-weight: 900;
  letter-spacing: 0.13em;
}

.home-v2-header-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 9px;
}

.live-badge {
  min-width: 96px;
  padding: 11px 19px;
  border: 1px solid rgba(57, 255, 136, 0.32);
  border-radius: 999px;
  background: rgba(57, 255, 136, 0.08);
  color: var(--nx-green);
  font-weight: 950;
  letter-spacing: 0.04em;
  text-align: center;
  box-shadow:
    0 0 26px rgba(57, 255, 136, 0.14),
    inset 0 0 18px rgba(57, 255, 136, 0.04);
}

.live-badge.warning {
  border-color: rgba(250, 204, 21, 0.35);
  background: rgba(250, 204, 21, 0.08);
  color: var(--nx-gold);
}

.live-badge.critical {
  border-color: rgba(251, 113, 133, 0.4);
  background: rgba(251, 113, 133, 0.08);
  color: var(--nx-red);
}

.home-v2-updated {
  color: var(--nx-muted);
  font-size: 0.75rem;
}

.nav {
  position: relative;
  margin: 16px 0;
}

.home-v2-status-strip {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 14px;
  padding: 0;
  border: 0;
  background: transparent;
}

.home-v2-status-strip .status-chip {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-width: 170px;
  min-height: 46px;
  padding: 0 16px;
  border: 1px solid var(--nx-border);
  border-radius: 999px;
  background:
    linear-gradient(
      145deg,
      rgba(10, 29, 56, 0.92),
      rgba(6, 19, 38, 0.92)
    );
  color: var(--nx-text);
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: 0.01em;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.025),
    0 8px 20px rgba(0, 0, 0, 0.14);
  transition:
    transform 150ms ease,
    border-color 150ms ease,
    box-shadow 150ms ease;
}

.home-v2-status-strip .status-chip:hover {
  transform: translateY(-2px);
  border-color: var(--nx-border-bright);
  box-shadow:
    0 12px 24px rgba(0, 0, 0, 0.2),
    var(--nx-glow-blue);
}

.home-v2-status-strip .status-chip span {
  width: 9px;
  height: 9px;
  flex: 0 0 9px;
}

.home-v2-status-strip .status-chip span {
  width: 10px;
  height: 10px;
  background: var(--nx-green);
  box-shadow:
    0 0 14px rgba(57, 255, 136, 0.9);
  animation:
    nexusHeartbeat 2s infinite;
}

.home-v2-status-strip .status-chip.warning span {
  background: var(--nx-gold);
}

.home-v2-status-strip .status-chip.critical span {
  background: var(--nx-red);
}

@keyframes nexusHeartbeat {
  0%,
  100% {
    transform: scale(0.92);
    opacity: 0.75;
  }

  45% {
    transform: scale(1.22);
    opacity: 1;
  }
}

.home-v2-hero-grid {
  display: grid;
  grid-template-columns:
    minmax(0, 2.35fr)
    minmax(320px, 0.9fr);
  gap: 16px;
  margin-top: 20px;
}

.nexus-card {
  border: 1px solid var(--nx-border);
  border-radius: 18px;
  background:
    linear-gradient(
      150deg,
      rgba(11, 30, 57, 0.92),
      rgba(6, 19, 38, 0.92)
    );
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.022);
}

.home-v2-hero-card {
  position: relative;
  min-height: 288px;
  overflow: hidden;
  padding: 32px;
  border-color: rgba(96, 165, 250, 0.32);
  background:
    radial-gradient(
      circle at 82% 45%,
      rgba(96, 165, 250, 0.16),
      transparent 42%
    ),
    linear-gradient(
      135deg,
      rgba(17, 51, 91, 0.96),
      rgba(9, 31, 61, 0.97)
    );
}

.home-v2-hero-card::before,
.home-v2-hero-card::after {
  content: "";
  position: absolute;
  pointer-events: none;
  border: 1px solid rgba(96, 165, 250, 0.08);
  border-radius: 50%;
}

.home-v2-hero-card::before {
  right: -120px;
  bottom: -190px;
  width: 510px;
  height: 510px;
}

.home-v2-hero-card::after {
  right: -45px;
  bottom: -116px;
  width: 355px;
  height: 355px;
}

.home-v2-eyebrow {
  position: relative;
  z-index: 1;
  color: #93c5fd;
  font-size: 0.75rem;
  font-weight: 950;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.home-v2-hero-number {
  position: relative;
  z-index: 1;
  margin-top: 22px;
  color: var(--nx-text);
  font-size: clamp(4rem, 8vw, 7rem);
  font-weight: 950;
  letter-spacing: -0.075em;
  line-height: 0.92;
  text-shadow:
    0 0 34px rgba(96, 165, 250, 0.18);
}

.home-v2-hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18px;
  color: #8dc5f4;
  font-size: 0.9rem;
}

.home-v2-hero-bar {
  position: relative;
  z-index: 1;
  height: 8px;
  margin-top: 32px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.1);
}

.home-v2-hero-bar div {
  width: 0;
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(
      90deg,
      var(--nx-blue-2),
      var(--nx-blue),
      var(--nx-green)
    );
  box-shadow:
    0 0 20px rgba(96, 165, 250, 0.65);
  transition:
    width 600ms ease;
}

.home-v2-health-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 288px;
  gap: 22px;
  padding: 28px;
  overflow: hidden;
}

.home-v2-health-card::after {
  content: "";
  position: absolute;
  inset: auto -60px -90px auto;
  width: 230px;
  height: 230px;
  border-radius: 50%;
  background:
    radial-gradient(
      circle,
      rgba(57, 255, 136, 0.11),
      transparent 65%
    );
}

.home-v2-health-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 11px;
}

.home-v2-health-copy strong {
  color: var(--nx-green);
  font-size: clamp(3rem, 5vw, 4.7rem);
  font-weight: 950;
  line-height: 1;
  text-shadow:
    0 0 24px rgba(57, 255, 136, 0.18);
}

.home-v2-health-copy span {
  color: #8dc5f4;
}

.home-v2-health-ring-wrap {
  position: relative;
  z-index: 1;
  width: 158px;
  min-width: 158px;
  height: 158px;
}

.home-v2-health-ring {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.home-v2-health-ring-track,
.home-v2-health-ring-value {
  fill: none;
  stroke-width: 10;
}

.home-v2-health-ring-track {
  stroke: rgba(96, 165, 250, 0.1);
}

.home-v2-health-ring-value {
  stroke: var(--nx-green);
  stroke-linecap: round;
  stroke-dasharray: 314.159;
  stroke-dashoffset: 314.159;
  filter:
    drop-shadow(
      0 0 9px rgba(57, 255, 136, 0.5)
    );
  transition:
    stroke-dashoffset 650ms ease;
}

.home-v2-health-ring-wrap > span {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: var(--nx-text);
  font-size: 1.4rem;
  font-weight: 950;
}

.home-v2-metrics {
  display: grid;
  grid-template-columns:
    repeat(6, minmax(0, 1fr));
  gap: 12px;
  margin-top: 18px;
}

.home-v2-metrics .metric-card {
  position: relative;
  min-height: 126px;
  overflow: hidden;
  padding: 20px;
  border: 1px solid var(--nx-border);
  border-radius: 16px;
  background:
    linear-gradient(
      150deg,
      rgba(11, 29, 55, 0.9),
      rgba(6, 18, 35, 0.92)
    );
  transition:
    transform 160ms ease,
    border-color 160ms ease,
    box-shadow 160ms ease;
}

.home-v2-metrics .metric-card:hover {
  transform: translateY(-3px);
  border-color: var(--nx-border-bright);
  box-shadow:
    0 16px 32px rgba(0, 0, 0, 0.24),
    var(--nx-glow-blue);
}

.home-v2-metrics .metric-card span {
  color: #7ec8ff;
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

.home-v2-metrics .metric-card strong {
  display: block;
  margin-top: 12px;
  color: var(--nx-blue);
  font-size: 1.8rem;
  font-weight: 950;
}

.home-v2-section {
  margin-top: 18px;
  padding: 22px;
}

.home-v2-section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
}

.home-v2-section-heading .label {
  color: var(--nx-text);
  font-size: 1rem;
  font-weight: 900;
}

.home-v2-section-heading .small {
  margin-top: 4px;
  color: var(--nx-muted);
  font-size: 0.77rem;
}

.home-v2-section-count,
.home-v2-chart-total {
  padding: 6px 10px;
  border: 1px solid rgba(96, 165, 250, 0.16);
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.07);
  color: #93c5fd;
  font-size: 0.74rem;
  font-weight: 900;
  white-space: nowrap;
}

.home-v2-coin-grid {
  display: grid;
  grid-template-columns:
    repeat(
      auto-fit,
      minmax(300px, 1fr)
    );
  gap: 13px;
}

.home-v2-coin-card {
  position: relative;
  min-height: 224px;
  overflow: hidden;
  padding: 20px;
  border: 1px solid var(--nx-border);
  border-radius: 16px;
  background:
    radial-gradient(
      circle at 85% 85%,
      rgba(96, 165, 250, 0.08),
      transparent 42%
    ),
    linear-gradient(
      145deg,
      rgba(16, 43, 78, 0.92),
      rgba(8, 24, 47, 0.94)
    );
  transition:
    transform 170ms ease,
    border-color 170ms ease,
    box-shadow 170ms ease;
}

.home-v2-coin-card:hover {
  transform: translateY(-3px);
  border-color: var(--nx-border-bright);
  box-shadow:
    0 17px 34px rgba(0, 0, 0, 0.25),
    var(--nx-glow-blue);
}

.home-v2-coin-card::after {
  content: attr(data-symbol);
  position: absolute;
  right: 12px;
  bottom: -24px;
  color: rgba(255, 255, 255, 0.032);
  font-size: 7rem;
  font-weight: 950;
  letter-spacing: -0.08em;
  pointer-events: none;
}

.home-v2-coin-card.mining {
  border-color: rgba(57, 255, 136, 0.34);
  box-shadow:
    inset 0 0 30px rgba(57, 255, 136, 0.025);
}

.home-v2-coin-card.node-online {
  border-color: rgba(96, 165, 250, 0.34);
}

.home-v2-coin-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.home-v2-coin-symbol {
  color: var(--nx-text);
  font-size: 1.45rem;
  font-weight: 950;
}

.home-v2-coin-name {
  margin-top: 4px;
  color: var(--nx-muted);
  font-size: 0.76rem;
}

.home-v2-state-badge {
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 4px 10px;
  border: 1px solid rgba(96, 165, 250, 0.3);
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.055);
  color: #93c5fd;
  font-size: 0.64rem;
  font-weight: 950;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.home-v2-state-badge.mining,
.home-v2-state-badge.active,
.home-v2-state-badge.online {
  border-color: rgba(57, 255, 136, 0.4);
  background: rgba(57, 255, 136, 0.07);
  color: var(--nx-green);
}

.home-v2-state-badge.warning {
  border-color: rgba(250, 204, 21, 0.38);
  color: var(--nx-gold);
}

.home-v2-state-badge.critical,
.home-v2-state-badge.offline {
  border-color: rgba(251, 113, 133, 0.4);
  color: var(--nx-red);
}

.home-v2-coin-hashrate {
  position: relative;
  z-index: 1;
  margin-top: 24px;
  color: var(--nx-text);
  font-size: 2rem;
  font-weight: 950;
}

.home-v2-coin-hashrate small {
  display: block;
  margin-top: 5px;
  color: #79b7e8;
  font-size: 0.7rem;
  font-weight: 500;
}

.home-v2-coin-stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns:
    repeat(3, minmax(0, 1fr));
  gap: 8px;
  margin-top: 20px;
}

.home-v2-mini-stat {
  min-width: 0;
  padding: 10px;
  border: 1px solid rgba(96, 165, 250, 0.11);
  border-radius: 10px;
  background: rgba(4, 15, 30, 0.46);
}

.home-v2-mini-stat strong {
  display: block;
  overflow: hidden;
  color: var(--nx-text);
  font-size: 0.96rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-v2-mini-stat span {
  display: block;
  margin-top: 4px;
  color: var(--nx-muted);
  font-size: 0.62rem;
}

.home-v2-pool-grid {
  display: grid;
  grid-template-columns:
    repeat(
      auto-fit,
      minmax(340px, 1fr)
    );
  gap: 13px;
}

.home-v2-pool-card {
  position: relative;
  padding: 20px;
  overflow: hidden;
  border: 1px solid var(--nx-border);
  border-radius: 16px;
  background:
    linear-gradient(
      145deg,
      rgba(15, 40, 74, 0.9),
      rgba(7, 22, 43, 0.94)
    );
  transition:
    transform 160ms ease,
    border-color 160ms ease;
}

.home-v2-pool-card:hover {
  transform: translateY(-2px);
  border-color: var(--nx-border-bright);
}

.home-v2-pool-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.home-v2-pool-card h3 {
  margin: 0;
  color: var(--nx-text);
  font-size: 1rem;
  font-weight: 900;
}

.home-v2-pool-endpoint {
  margin-top: 5px;
  color: #79b7e8;
  font-family: monospace;
  font-size: 0.7rem;
}

.home-v2-pool-hashrate {
  margin-top: 22px;
  color: var(--nx-blue);
  font-size: 2rem;
  font-weight: 950;
  text-shadow:
    0 0 22px rgba(96, 165, 250, 0.18);
}

.home-v2-pool-stats {
  display: grid;
  grid-template-columns:
    repeat(3, minmax(0, 1fr));
  gap: 8px;
  margin-top: 17px;
}

.home-v2-pool-progress {
  height: 7px;
  margin-top: 18px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.08);
}

.home-v2-pool-progress div {
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(
      90deg,
      var(--nx-blue),
      var(--nx-cyan),
      var(--nx-green)
    );
  box-shadow:
    0 0 16px rgba(96, 165, 250, 0.42);
}

.home-v2-two-column {
  display: grid;
  grid-template-columns:
    minmax(0, 1.55fr)
    minmax(390px, 0.88fr);
  gap: 16px;
  margin-top: 18px;
}

.home-v2-chart-card,
.home-v2-miners-card,
.home-v2-two-column > .nexus-card {
  padding: 20px;
}

.home-v2-line-chart {
  width: 100%;
  min-height: 430px;
}

.home-v2-chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  min-height: 28px;
  margin-bottom: 8px;
}

.home-v2-chart-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 8px;
  border: 1px solid rgba(96, 165, 250, 0.09);
  border-radius: 999px;
  color: var(--nx-muted);
  font-size: 0.69rem;
}

.home-v2-chart-legend-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  box-shadow:
    0 0 10px currentColor;
}

.home-v2-miner-list,
.home-v2-node-list,
.home-v2-alert-list {
  display: flex;
  flex-direction: column;
  gap: 9px;
}

.home-v2-miner-row {
  display: grid;
  grid-template-columns:
    48px
    minmax(0, 1fr)
    auto;
  gap: 12px;
  align-items: center;
  padding: 13px;
  border: 1px solid rgba(96, 165, 250, 0.13);
  border-radius: 12px;
  background:
    linear-gradient(
      145deg,
      rgba(9, 26, 50, 0.72),
      rgba(5, 17, 34, 0.75)
    );
  transition:
    transform 150ms ease,
    border-color 150ms ease;
}

.home-v2-miner-row:hover {
  transform: translateX(3px);
  border-color: rgba(96, 165, 250, 0.34);
}

.home-v2-miner-rank {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border: 1px solid rgba(96, 165, 250, 0.29);
  border-radius: 11px;
  background: rgba(37, 99, 235, 0.11);
  color: #93c5fd;
  font-weight: 950;
}

.home-v2-miner-name {
  color: var(--nx-text);
  font-weight: 900;
}

.home-v2-miner-pool {
  margin-top: 4px;
  color: var(--nx-muted);
  font-size: 0.7rem;
}

.home-v2-miner-values {
  text-align: right;
}

.home-v2-miner-values strong {
  display: block;
  color: var(--nx-green);
  font-size: 0.94rem;
}

.home-v2-miner-values span {
  display: block;
  margin-top: 4px;
  color: var(--nx-muted);
  font-size: 0.65rem;
}

.home-v2-node-row,
.home-v2-alert-row {
  padding: 15px;
  border: 1px solid rgba(96, 165, 250, 0.13);
  border-radius: 12px;
  background:
    linear-gradient(
      145deg,
      rgba(9, 26, 50, 0.7),
      rgba(5, 17, 34, 0.72)
    );
}

.home-v2-node-row-header,
.home-v2-alert-row-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 13px;
}

.home-v2-node-row h3,
.home-v2-alert-row h3 {
  margin: 0;
  color: var(--nx-text);
  font-size: 0.9rem;
}

.home-v2-node-host,
.home-v2-alert-source {
  margin-top: 4px;
  color: #79b7e8;
  font-family: monospace;
  font-size: 0.67rem;
}

.home-v2-node-stats {
  display: grid;
  grid-template-columns:
    repeat(3, minmax(0, 1fr));
  gap: 8px;
  margin-top: 14px;
}

.home-v2-alert-row.warning {
  border-color: rgba(250, 204, 21, 0.26);
}

.home-v2-alert-row.critical {
  border-color: rgba(251, 113, 133, 0.34);
}

.home-v2-alert-message {
  margin-top: 10px;
  color: var(--nx-muted);
  font-size: 0.77rem;
  line-height: 1.45;
}

.home-v2-all-clear {
  padding: 27px;
  border: 1px solid rgba(57, 255, 136, 0.25);
  border-radius: 12px;
  background:
    radial-gradient(
      circle at 50% 100%,
      rgba(57, 255, 136, 0.08),
      transparent 60%
    ),
    rgba(57, 255, 136, 0.04);
  color: var(--nx-green);
  text-align: center;
  font-weight: 950;
  box-shadow:
    inset 0 0 24px rgba(57, 255, 136, 0.025);
}

.home-v2-activity-feed {
  display: grid;
  grid-template-columns:
    repeat(
      auto-fit,
      minmax(280px, 1fr)
    );
  gap: 9px;
}

.home-v2-activity-feed .event {
  min-height: 78px;
  padding: 13px;
  border-radius: 10px;
  background:
    linear-gradient(
      145deg,
      rgba(8, 24, 46, 0.72),
      rgba(5, 16, 32, 0.78)
    );
  transition:
    transform 140ms ease;
}

.home-v2-activity-feed .event:hover {
  transform: translateY(-2px);
}

.home-v2-loading,
.home-v2-empty {
  padding: 30px;
  border: 1px dashed rgba(96, 165, 250, 0.19);
  border-radius: 12px;
  color: var(--nx-muted);
  text-align: center;
}

.home-v2-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 22px 5px 4px;
  color: var(--nx-muted);
  font-size: 0.7rem;
}

.home-v2-footer a {
  color: #7ec8ff;
  text-decoration: none;
}

.home-v2-footer a:hover {
  color: var(--nx-text);
}

body.command-tv .home-v2-footer {
  display: none;
}

@media (min-width: 1700px) {
  .home-v2-coin-grid {
    grid-template-columns:
      repeat(4, minmax(0, 1fr));
  }

  .home-v2-pool-grid {
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 1280px) {
  .home-v2-metrics {
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
  }

  .home-v2-two-column {
    grid-template-columns: 1fr;
  }

  .home-v2-status-strip {
    justify-content: flex-start;
  }
}

@media (max-width: 900px) {
  .home-v2-wrap {
    width: min(100% - 18px, 1680px);
    margin-top: 9px;
  }

  .home-v2-panel {
    padding: 12px;
    border-radius: 18px;
  }

  .home-v2-header {
    flex-direction: column;
    padding: 20px;
  }

  .home-v2-header-status {
    align-items: flex-start;
  }

  .home-v2-hero-grid {
    grid-template-columns: 1fr;
  }

  .home-v2-status-strip .status-chip {
    min-width: 145px;
  }

  .home-v2-line-chart {
    min-height: 340px;
  }
}

@media (max-width: 620px) {
  .home-v2-title-row h1 {
    font-size: 2rem;
  }

  .home-v2-status-strip {
    display: grid;
    grid-template-columns: 1fr;
  }

  .home-v2-status-strip .status-chip {
    width: 100%;
  }

  .home-v2-metrics {
    grid-template-columns: 1fr;
  }

  .home-v2-hero-card,
  .home-v2-health-card {
    min-height: auto;
    padding: 20px;
  }

  .home-v2-health-card {
    flex-direction: column;
    align-items: flex-start;
  }

  .home-v2-coin-grid,
  .home-v2-pool-grid {
    grid-template-columns: 1fr;
  }

  .home-v2-coin-stats,
  .home-v2-pool-stats,
  .home-v2-node-stats {
    grid-template-columns: 1fr;
  }

  .home-v2-miner-row {
    grid-template-columns:
      42px
      minmax(0, 1fr);
  }

  .home-v2-miner-values {
    grid-column: 2;
    text-align: left;
  }

  .home-v2-footer {
    flex-direction: column;
    align-items: flex-start;
  }
}
