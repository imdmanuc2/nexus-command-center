"""Nexus CMDB observation store.

Collectors and discovery systems report what they observed here. An
observation is evidence, not authoritative CMDB state.
"""

from __future__ import annotations

import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any
from uuid import uuid4


OBSERVATION_DB = Path(
    "backend/data/cmdb/observations/observations.jsonl"
)


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _string(value: Any) -> str:
    if value is None:
        return ""
    return str(value).strip()


def _normalize_list(value: Any) -> list[Any]:
    if value is None:
        return []

    if isinstance(value, list):
        return value

    if isinstance(value, (tuple, set)):
        return list(value)

    return [value]


def normalize_observation(
    payload: dict[str, Any],
    *,
    source: str = "unknown",
    observer_id: str = "nexus",
    correlation_id: str | None = None,
) -> dict[str, Any]:
    if not isinstance(payload, dict):
        raise ValueError("Observation payload must be an object.")

    observed_at = (
        payload.get("observedAt")
        or payload.get("lastSeen")
        or now_iso()
    )

    identity = dict(payload.get("identity") or {})

    normalized = {
        "observationId": (
            payload.get("observationId")
            or f"obs-{uuid4().hex}"
        ),
        "observedAt": observed_at,
        "receivedAt": now_iso(),
        "source": payload.get("source") or source,
        "observerId": (
            payload.get("observerId")
            or observer_id
        ),
        "correlationId": (
            payload.get("correlationId")
            or correlation_id
            or f"corr-{uuid4().hex}"
        ),
        "status": payload.get("status") or "pending",
        "decision": payload.get("decision") or "",
        "matchedAssetId": (
            payload.get("matchedAssetId")
            or ""
        ),
        "confidence": payload.get("confidence"),
        "identity": {
            "ip": _string(
                identity.get("ip")
                or payload.get("ip")
            ),
            "macAddress": _string(
                identity.get("macAddress")
                or payload.get("macAddress")
                or payload.get("mac")
            ).lower(),
            "serialNumber": _string(
                identity.get("serialNumber")
                or payload.get("serialNumber")
                or payload.get("serial")
            ),
            "hostname": _string(
                identity.get("hostname")
                or payload.get("hostname")
            ).lower(),
            "machineUuid": _string(
                identity.get("machineUuid")
                or payload.get("machineUuid")
                or payload.get("systemUuid")
                or payload.get("vmUuid")
            ).lower(),
            "sshHostKey": _string(
                identity.get("sshHostKey")
                or payload.get("sshHostKey")
            ),
            "workerId": _string(
                identity.get("workerId")
                or payload.get("workerId")
            ),
            "poolId": _string(
                identity.get("poolId")
                or payload.get("poolId")
            ),
        },
        "classification": {
            "assetType": (
                payload.get("assetType")
                or payload.get("canonicalType")
                or payload.get("type")
                or "unknown"
            ),
            "primaryRole": (
                payload.get("primaryRole")
                or ""
            ),
            "purpose": payload.get("purpose") or "",
        },
        "network": {
            "ip": _string(payload.get("ip")),
            "openPorts": _normalize_list(
                payload.get("openPorts")
                or payload.get("ports")
            ),
            "services": _normalize_list(
                payload.get("services")
            ),
        },
        "compute": {
            "computeProfile": (
                payload.get("computeProfile")
                if isinstance(
                    payload.get("computeProfile"),
                    dict,
                )
                else {}
            ),
            "components": _normalize_list(
                payload.get("components")
            ),
            "capabilities": _normalize_list(
                payload.get("capabilities")
            ),
            "workloads": _normalize_list(
                payload.get("workloads")
            ),
        },
        "raw": payload,
    }

    return normalized


def append_observation(
    payload: dict[str, Any],
    *,
    source: str = "unknown",
    observer_id: str = "nexus",
    correlation_id: str | None = None,
) -> dict[str, Any]:
    observation = normalize_observation(
        payload,
        source=source,
        observer_id=observer_id,
        correlation_id=correlation_id,
    )

    OBSERVATION_DB.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    with OBSERVATION_DB.open(
        "a",
        encoding="utf-8",
    ) as handle:
        handle.write(
            json.dumps(
                observation,
                separators=(",", ":"),
            )
            + "\n"
        )

    return observation


def read_observations(
    *,
    status: str | None = None,
    matched_asset_id: str | None = None,
    correlation_id: str | None = None,
    limit: int = 200,
) -> list[dict[str, Any]]:
    if not OBSERVATION_DB.exists():
        return []

    safe_limit = max(1, min(int(limit), 5000))
    observations: list[dict[str, Any]] = []

    with OBSERVATION_DB.open(
        "r",
        encoding="utf-8",
    ) as handle:
        for line in handle:
            line = line.strip()

            if not line:
                continue

            try:
                observation = json.loads(line)
            except json.JSONDecodeError:
                continue

            if (
                status
                and observation.get("status") != status
            ):
                continue

            if (
                matched_asset_id
                and observation.get("matchedAssetId")
                != matched_asset_id
            ):
                continue

            if (
                correlation_id
                and observation.get("correlationId")
                != correlation_id
            ):
                continue

            observations.append(observation)

    observations.sort(
        key=lambda item: item.get(
            "receivedAt",
            "",
        ),
        reverse=True,
    )

    return observations[:safe_limit]
